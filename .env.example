# Authentication mode: interactive | client-secret | certificate | client-token | oauth-proxy
MS365_AUTH_MODE=interactive
MS365_TENANT_ID=common
MS365_CLIENT_ID=your-azure-app-client-id

# Client secret (required for client-secret and oauth-proxy modes)
# MS365_CLIENT_SECRET=

# Certificate (required for certificate mode)
# MS365_CERT_PATH=
# MS365_CERT_PASSWORD=

# Client token (optional initial token for client-token mode)
# MS365_ACCESS_TOKEN=

# OAuth proxy (required for oauth-proxy mode)
# MS365_OAUTH_BASE_URL=http://localhost:3000
# Dedicated secrets for oauth-proxy mode. STRONGLY recommended in production —
# if unset they fall back to MS365_CLIENT_SECRET (key reuse; logged as a warning).
# Changing MS365_TOKEN_ENCRYPTION_KEY invalidates persisted tokens (users re-auth once).
# MS365_JWT_SIGNING_KEY=
# MS365_TOKEN_ENCRYPTION_KEY=
# Where encrypted OAuth tokens persist (created mode 0700). Default: /tmp/ms365-tokens.
# Recommend a persistent, private path (NOT world-writable /tmp) for real deployments.
# TOKEN_STORAGE_PATH=

# Upload relay auth (non-oauth httpStream only). REQUIRED to enable the /upload endpoint
# outside oauth-proxy mode — without it the endpoint refuses requests (503) rather than
# uploading with the server's own credentials.
# MS365_UPLOAD_TOKEN=

# Transport: stdio (default) | httpStream
# TRANSPORT_TYPE=stdio
# PORT=3000
# Bind address for httpStream. Default 127.0.0.1 (loopback). Set 0.0.0.0 to expose
# on all interfaces (the Docker image sets FASTMCP_HOST=0.0.0.0 for this reason).
# HOST=127.0.0.1

# Tool filtering
# MS365_PRESETS=personal              # personal | collaboration | productivity | all
# MS365_ENABLED_TOOLS=                # regex pattern, e.g. "mail|calendar"
# MS365_READ_ONLY=false
# MS365_ORG_MODE=false

# Graph API version: v1.0 (default) | beta
# MS365_GRAPH_VERSION=v1.0
