{
  "name": "microsoft365-mcp-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Monorepo for the Microsoft Graph MCP servers (microsoft365 + shared core).",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485",
  "scripts": {
    "validate": "pnpm -r validate",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "lint:check": "pnpm -r lint:check",
    "format": "pnpm -r format",
    "format:check": "pnpm -r format:check",
    "build:mcpb": "pnpm --filter microsoft365-mcp-server build:mcpb"
  },
  "devDependencies": {
    "ts-builds": "^3.2.0"
  }
}
