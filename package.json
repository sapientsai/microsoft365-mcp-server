{
  "name": "microsoft365-mcp-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Monorepo for the Microsoft Graph MCP servers (microsoft365 + shared core).",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "scripts": {
    "validate": "pnpm -r validate",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "lint:check": "pnpm -r lint:check",
    "format": "pnpm -r format",
    "format:check": "pnpm -r format:check",
    "build:mcpb": "pnpm --filter microsoft365-mcp-server build:mcpb"
  },
  "devDependencies": {
    "ts-builds": "^3.2.1"
  }
}
