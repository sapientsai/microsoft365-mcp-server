# --- App-only auth (client_credentials) — REQUIRED ---
# A concrete tenant ID (NOT "common"/"organizations"/"consumers" — app-only needs a real tenant).
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
# Comma-separated app scopes. Default: https://graph.microsoft.com/.default
# MS_GRAPH_APP_SCOPES=https://graph.microsoft.com/.default

# --- Transport ---
# httpStream (default) | stdio
# TRANSPORT_TYPE=httpStream
# PORT=8080
# Bind address. Default 127.0.0.1; the Docker image sets FASTMCP_HOST=0.0.0.0.
# HOST=127.0.0.1

# --- Relay auth (httpStream) ---
# Shared key gating the MCP transport AND the /upload route. REQUIRED to enable /upload;
# without it the endpoint refuses requests (503). get_upload_config returns an opaque
# ticket (never the raw key) in its curl.
# MCP_API_KEY=
# Public base URL used in the get_upload_config curl. Defaults to http://HOST:PORT.
# MCP_PUBLIC_BASE_URL=https://your-server.example.com

# --- SharePoint search ---
# Graph Search API region (app-only requires a region). Default NAM.
# GRAPH_SEARCH_REGION=NAM
# Optional default site to scope searches/uploads.
# SITE_ID=
# SITE_URL=https://contoso.sharepoint.com/sites/yoursite

# --- Azure AI Search (optional — azure_ai_search tool only registers when all three are set) ---
# AZURE_AI_SEARCH_ENDPOINT=https://your-search.search.windows.net
# AZURE_AI_SEARCH_API_KEY=
# AZURE_AI_SEARCH_INDEX=
# AZURE_AI_SEARCH_SEMANTIC_CONFIG=
# AZURE_AI_SEARCH_VECTOR_FIELDS=contentVector
# AZURE_AI_SEARCH_SELECT_FIELDS=

# --- Optional tool-description augmentation ---
# MCP_INSTRUCTIONS=
