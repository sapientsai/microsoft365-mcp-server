{
  "name": "microsoft-mcp-server",
  "version": "0.0.0",
  "private": true,
  "description": "App-only (client_credentials) Microsoft Graph MCP server for headless document-RAG — the successor to the archived sapientsai/microsoft-mcp-server, rebuilt on somamcp + @sapientsai/ms-graph-core. Sibling to the delegated microsoft365-mcp-server.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "microsoft-mcp-server": "dist/bin.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "validate": "ts-builds validate",
    "format": "ts-builds format",
    "format:check": "ts-builds format:check",
    "lint": "ts-builds lint",
    "lint:check": "ts-builds lint:check",
    "typecheck": "ts-builds typecheck",
    "test": "ts-builds test",
    "test:watch": "ts-builds test:watch",
    "test:coverage": "ts-builds test:coverage",
    "build": "NODE_ENV=production ts-builds build",
    "dev": "ts-builds dev"
  },
  "prettier": "ts-builds/prettier",
  "dependencies": {
    "@sapientsai/ms-graph-core": "workspace:*",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "functype": "1.4.4",
    "mammoth": "^1.12.0",
    "somamcp": "^1.1.0",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "ts-builds": "^3.2.1",
    "tsdown": "^0.22.3"
  },
  "engines": {
    "node": ">=22"
  }
}
